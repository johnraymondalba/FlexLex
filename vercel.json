{
  "buildCommand": "mkdir -p frontend/dist && cp frontend/index.html frontend/dist/index.html",
  "outputDirectory": "frontend/dist",
  "public": false,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api|_next/static|favicon).*)",
      "destination": "/index.html"
    }
  ]
}

